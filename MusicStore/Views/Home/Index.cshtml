@{
    ViewData["Title"] = "דף הבית";
    var categories = ViewBag.Categories as List<Category>;
    var featured = ViewBag.FeaturedProducts as List<Product>;
}

<section class="hero">
    <div class="container hero-content">
        <span class="hero-eyebrow">★ חנות הנגינה המובילה בישראל ★</span>
        <h1>הצליל שלך<br /><span class="accent">מתחיל כאן</span></h1>
        <p>מבחר ענק של כלי נגינה איכותיים, ציוד מקצועי ואביזרים – הכל במקום אחד. משלוח חינם בקנייה מעל 500₪.</p>
        <div class="hero-cta">
            <a href="/Products" class="btn-primary">
                גלה את הקטלוג
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M19 12H5M12 19l-7-7 7-7" />
                </svg>
            </a>
            <a href="/Home/About" class="btn-secondary">למד עלינו</a>
        </div>
    </div>
</section>

<section>
    <div class="container">
        <div class="section-header">
            <h2>גלה <span class="gold-text">לפי קטגוריה</span></h2>
            <p>מהגיטרה הראשונה ועד הכלי המקצועי – יש לנו את כל מה שאתה צריך</p>
        </div>
        <div class="categories-grid">
            @if (categories != null)
            {
                foreach (var cat in categories)
                {
                    <a href="/Products?categoryId=@cat.CategoryID" class="category-card">
                        <span class="category-icon">@cat.Icon</span>
                        <div class="category-name">@cat.CategoryName</div>
                    </a>
                }
            }
        </div>
    </div>
</section>

<section style="background: var(--bg-secondary);">
    <div class="container">
        <div class="section-header">
            <h2>מוצרים <span class="gold-text">נבחרים</span></h2>
            <p>הפריטים הפופולריים והאיכותיים ביותר שלנו</p>
        </div>
        <div class="products-grid">
            @if (featured != null)
            {
                foreach (var p in featured)
                {
                    <div class="product-card">
                        <div class="product-image">
                            <img src="@p.Image" alt="@p.ProductName" loading="lazy" />
                            @if (p.Stock < 5)
                            {
                                <span class="product-badge">אחרונים במלאי</span>
                            }
                        </div>
                        <div class="product-info">
                            <div class="product-brand">@p.Brand</div>
                            <div class="product-name">@p.ProductName</div>
                            <div class="product-price">
                                <span class="currency">₪</span>@p.Price.ToString("N0")
                            </div>
                            <div class="product-actions">
                                <a href="/Products/Details/@p.ProductID" class="btn-view">פרטים</a>
                                <form method="post" action="/Cart/Add" style="display:inline;">
                                    <input type="hidden" name="productId" value="@p.ProductID" />
                                    <button type="submit" class="btn-add-cart">+ עגלה</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <div style="text-align:center; margin-top: 48px;">
            <a href="/Products" class="btn-primary">ראה את כל המוצרים</a>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="container">
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🚚</div>
                <h3>משלוח חינם</h3>
                <p>בקנייה מעל 500₪ ברחבי הארץ</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🛡️</div>
                <h3>אחריות מלאה</h3>
                <p>שנת אחריות יצרן על כל המוצרים</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⭐</div>
                <h3>איכות מקצועית</h3>
                <p>מותגים מובילים מכל העולם</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">💬</div>
                <h3>תמיכה אישית</h3>
                <p>צוות מומחים זמין לכל שאלה</p>
            </div>
        </div>
    </div>
</section>
