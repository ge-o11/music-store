@{
    ViewData["Title"] = "אודות";
}

<section class="page-header">
    <div class="container">
        <h1>אודות <span class="gold-text">MusicStore</span></h1>
        <p>מעל 30 שנה של מקצועיות, איכות ואהבה למוזיקה</p>
    </div>
</section>

<section>
    <div class="container" style="max-width: 800px;">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 20px;">הסיפור שלנו</h2>
        <p style="color: var(--text-secondary); font-size: 17px; line-height: 1.9; margin-bottom: 24px;">
            MusicStore נוסדה ב-1995 על ידי קבוצת מוזיקאים מקצועיים שרצו להביא לישראל את הציוד המוזיקלי הטוב בעולם.
            במהלך השנים הפכנו לחנות הנגינה המובילה בארץ, עם שיתופי פעולה עם המותגים הגדולים בעולם.
        </p>
        <p style="color: var(--text-secondary); font-size: 17px; line-height: 1.9; margin-bottom: 40px;">
            הצוות שלנו מורכב ממוזיקאים, טכנאים ויועצים מקצועיים שיעזרו לך למצוא את הכלי המושלם –
            בין אם אתה מנגן מתחיל או מקצוען בעל ניסיון של עשרות שנים.
        </p>

        <div class="features-grid" style="margin-top: 60px;">
            <div class="feature-card" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;">
                <div class="feature-icon">🎯</div>
                <h3>החזון שלנו</h3>
                <p>להפוך את עולם המוזיקה לנגיש לכל אחד</p>
            </div>
            <div class="feature-card" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;">
                <div class="feature-icon">💎</div>
                <h3>איכות בלבד</h3>
                <p>כל מוצר נבחר בקפידה על ידי מומחים</p>
            </div>
            <div class="feature-card" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;">
                <div class="feature-icon">🤝</div>
                <h3>שירות אישי</h3>
                <p>ליווי מקצועי לפני ואחרי הרכישה</p>
            </div>
        </div>
    </div>
</section>
