@model Product
@{
    ViewData["Title"] = "הוסף מוצר";
    var categories = ViewBag.Categories as List<Category>;
}

<section class="page-header">
    <div class="container">
        <h1>הוסף <span class="gold-text">מוצר חדש</span></h1>
        <p>מלא את הפרטים והוסף לקטלוג</p>
    </div>
</section>

<section style="padding: 40px 0;">
    <div class="container" style="max-width: 700px;">
        @if (ViewBag.Error != null)
        {
            <div class="form-error">@ViewBag.Error</div>
        }

        <form method="post" action="/Admin/AddProduct" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px;">
            <div class="form-group">
                <label>שם המוצר</label>
                <input type="text" name="ProductName" required />
            </div>

            <div class="form-group">
                <label>מותג</label>
                <input type="text" name="Brand" required />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div class="form-group">
                    <label>מחיר (₪)</label>
                    <input type="number" name="Price" step="0.01" min="0" required />
                </div>
                <div class="form-group">
                    <label>מלאי</label>
                    <input type="number" name="Stock" min="0" value="10" required />
                </div>
            </div>

            <div class="form-group">
                <label>קטגוריה</label>
                <select name="CategoryID" required>
                    @if (categories != null)
                    {
                        foreach (var c in categories)
                        {
                            <option value="@c.CategoryID">@c.Icon @c.CategoryName</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label>קישור לתמונה</label>
                <input type="url" name="Image" placeholder="https://..." />
            </div>

            <div class="form-group">
                <label>תיאור</label>
                <textarea name="Description" rows="5" required></textarea>
            </div>

            <div style="display:flex; gap:12px;">
                <button type="submit" class="btn-submit">הוסף מוצר</button>
                <a href="/Admin" class="btn-secondary" style="display:inline-flex; align-items:center;">ביטול</a>
            </div>
        </form>
    </div>
</section>
